{
  "name": "n8n-infrastructure",
  "version": "1.0.0",
  "description": "Production-ready n8n infrastructure with AI integrations and automated knowledge management",
  "private": true,
  "keywords": [
    "n8n",
    "workflow-automation",
    "ai-integration",
    "langchain",
    "vector-database",
    "hugging-face",
    "supabase",
    "devops"
  ],
  "scripts": {
    "dev": "node scripts/check-environment.js && echo 'Environment check completed. In WebContainer, use deployment workflows for full functionality.'",
    "start": "node scripts/check-environment.js && echo 'Starting n8n production environment...'",
    "stop": "echo 'Stopping n8n services...'",
    "logs": "echo 'Viewing n8n logs...'",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "sync-knowledge": "bash scripts/sync-knowledge.sh",
    "build": "docker-compose -f docker/docker-compose.yml build",
    "build": "node scripts/check-environment.js && echo 'Building n8n container...'",
    "clean": "echo 'Cleaning up n8n resources...'",
    "test": "bash scripts/test-infrastructure.sh",
    "validate-secrets": "node scripts/validate-secrets.js",
    "security-check": "node scripts/security-check.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danilonovaisv/n8n-infra.git"
  },
  "author": {
    "name": "Danilo Novais",
    "email": "danilo_novais@yahoo.com.br"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "openai": "^5.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
